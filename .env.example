GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
GCP_STAGING_BUCKET=your-project-id-geap-staging

# MCP server URLs (set after deploying to Cloud Run)
SEARCH_MCP_URL=https://search-mcp-xxx-uc.a.run.app/mcp
BOOKING_MCP_URL=https://booking-mcp-xxx-uc.a.run.app/mcp
EXPENSE_MCP_URL=https://expense-mcp-xxx-uc.a.run.app/mcp

# Agent Gateway — regional for Agent Runtime, global for Gemini Enterprise
AGENT_GATEWAY_PATH=projects/your-project-id/locations/us-central1/agentGateways/geap-workshop-gateway
AGENT_GATEWAY_EGRESS_PATH=projects/your-project-id/locations/us-central1/agentGateways/geap-workshop-gateway-egress

# Model Armor templates
MODEL_ARMOR_PROMPT_TEMPLATE=projects/your-project-id/locations/us-central1/templates/geap-workshop-prompt
MODEL_ARMOR_RESPONSE_TEMPLATE=projects/your-project-id/locations/us-central1/templates/geap-workshop-response

# Agent Engine IDs (set after deploying agents)
AGENT_ENGINE_ID=your-coordinator-engine-id
ROUTER_ENGINE_ID=your-router-engine-id

# Multi-model router
LITE_MODEL=gemini-2.0-flash-lite
FLASH_MODEL=gemini-2.5-flash
OPUS_MODEL=vertex_ai/claude-opus-4-7
COMPLEXITY_THRESHOLD_HIGH=0.65
CLASSIFIER_MODEL=gemini-2.0-flash-lite
