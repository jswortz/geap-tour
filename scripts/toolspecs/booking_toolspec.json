{
  "tools": [
    {
      "name": "book_flight",
      "description": "Book a flight by flight ID and passenger name.",
      "inputSchema": {
        "type": "object",
        "required": ["flight_id", "passenger_name"],
        "properties": {
          "flight_id": {"type": "string", "description": "Flight ID to book"},
          "passenger_name": {"type": "string", "description": "Passenger full name"}
        }
      },
      "annotations": {"title": "Book Flight"}
    },
    {
      "name": "book_hotel",
      "description": "Book a hotel by hotel ID, guest name, and dates.",
      "inputSchema": {
        "type": "object",
        "required": ["hotel_id", "guest_name", "check_in", "check_out"],
        "properties": {
          "hotel_id": {"type": "string", "description": "Hotel ID"},
          "guest_name": {"type": "string", "description": "Guest name"},
          "check_in": {"type": "string", "description": "Check-in date (YYYY-MM-DD)"},
          "check_out": {"type": "string", "description": "Check-out date (YYYY-MM-DD)"}
        }
      },
      "annotations": {"title": "Book Hotel"}
    },
    {
      "name": "get_booking",
      "description": "Get booking details by booking ID.",
      "inputSchema": {
        "type": "object",
        "required": ["booking_id"],
        "properties": {
          "booking_id": {"type": "string", "description": "Booking ID to retrieve"}
        }
      },
      "annotations": {"title": "Get Booking", "readOnlyHint": true}
    }
  ]
}
