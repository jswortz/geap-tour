{
  "tools": [
    {
      "name": "submit_expense",
      "description": "Submit an expense report with employee ID, category, amount, and description.",
      "inputSchema": {
        "type": "object",
        "required": ["employee_id", "category", "amount", "description"],
        "properties": {
          "employee_id": {"type": "string", "description": "Employee ID"},
          "category": {"type": "string", "description": "Expense category (meals, transport, lodging, supplies, entertainment)"},
          "amount": {"type": "number", "description": "Expense amount in USD"},
          "description": {"type": "string", "description": "Expense description"}
        }
      },
      "annotations": {"title": "Submit Expense"}
    },
    {
      "name": "check_expense_policy",
      "description": "Check expense policy limits for a given category.",
      "inputSchema": {
        "type": "object",
        "required": ["category"],
        "properties": {
          "category": {"type": "string", "description": "Category to check policy for"}
        }
      },
      "annotations": {"title": "Check Expense Policy", "readOnlyHint": true}
    },
    {
      "name": "get_user_expenses",
      "description": "Get expense history for a specific employee.",
      "inputSchema": {
        "type": "object",
        "required": ["employee_id"],
        "properties": {
          "employee_id": {"type": "string", "description": "Employee ID to look up"}
        }
      },
      "annotations": {"title": "Get User Expenses", "readOnlyHint": true}
    }
  ]
}
