{
  "tools": [
    {
      "name": "search_flights",
      "description": "Search available flights by origin, destination, and optional date.",
      "inputSchema": {
        "type": "object",
        "required": ["origin", "destination"],
        "properties": {
          "origin": {"type": "string", "description": "Origin airport code (e.g., SFO)"},
          "destination": {"type": "string", "description": "Destination airport code (e.g., JFK)"},
          "date": {"type": "string", "description": "Date filter (YYYY-MM-DD)"}
        }
      },
      "annotations": {"title": "Search Flights", "readOnlyHint": true}
    },
    {
      "name": "search_hotels",
      "description": "Search available hotels by city with optional max price filter.",
      "inputSchema": {
        "type": "object",
        "required": ["city"],
        "properties": {
          "city": {"type": "string", "description": "City name"},
          "max_price": {"type": "number", "description": "Max price per night"}
        }
      },
      "annotations": {"title": "Search Hotels", "readOnlyHint": true}
    }
  ]
}
